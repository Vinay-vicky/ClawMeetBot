PORT=3000

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_ID=-100your_group_id_here

# Microsoft Azure App Registration
TEAMS_APP_ID=your_azure_client_id
TEAMS_APP_PASSWORD=your_azure_client_secret
TEAMS_TENANT_ID=your_azure_tenant_id

# Outlook calendar user
OUTLOOK_USER_EMAIL=you@yourdomain.com

# Timezone (e.g. Asia/Kolkata, Asia/Dubai, UTC)
TIMEZONE=Asia/Kolkata

# Base URL for random meet links
MEET_LINK_BASE_URL=https://meet.google.com

# OpenAI (for AI meeting summaries — get from platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# Turso (persistent cloud SQLite — free at https://turso.tech)
# Create a DB → Settings → copy the URL and auth token
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
